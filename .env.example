# Workato webhook URLs (copy from the recipe webhook triggers)
RECIPE_1_WEBHOOK_URL=https://webhooks.workato.com/webhooks/rest/REPLACE/lci_seller_intake
RECIPE_2_WEBHOOK_URL=https://webhooks.workato.com/webhooks/rest/REPLACE/lci_verification_result
# Optional buy-side extension (Shopify). Leave blank to skip.
RECIPE_4_WEBHOOK_URL=

# Jira Cloud (only needed for scripts/setup_jira.rb)
JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=replace_with_api_token
# Optional: set to auto-create the project; find it at /rest/api/3/myself (accountId)
JIRA_LEAD_ACCOUNT_ID=
