# Workato webhook URLs (copy from each recipe's webhook trigger step)
# All three recipes share the same webhook base; only the path suffix differs.

# Recipe 1: Seller Intake (lci_intake). Fires Amelia and Daniel intakes.
INTAKE_WEBHOOK_URL=https://webhooks.trial.workato.com/webhooks/rest/REPLACE/lci_intake

# LCI Senior Decision (lci_decision). Submits approve / reject decisions.
DECISION_WEBHOOK_URL=https://webhooks.trial.workato.com/webhooks/rest/REPLACE/lci_decision

# Optional Phase 2 bonus: Cleaning Complete -> Ready for Listing (lci_cleaning_complete).
# Leave blank to skip the cleaning step entirely.
CLEANING_WEBHOOK_URL=

# Jira Cloud (only needed for scripts/setup_jira.rb)
JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=replace_with_api_token
# Optional: set to auto-create the project; find it at /rest/api/3/myself (accountId)
JIRA_LEAD_ACCOUNT_ID=
